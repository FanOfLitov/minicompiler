section .text
global main

add:
    push rbp
    mov rbp, rsp
    sub rsp, 48
    mov qword [rbp-8], rdi
    mov qword [rbp-16], rsi
.L_add_entry:
    mov rax, qword [rbp-8]
    mov qword [rbp-24], rax
    mov rax, qword [rbp-16]
    mov qword [rbp-32], rax
    mov rax, qword [rbp-24]
    mov rbx, qword [rbp-32]
    add rax, rbx
    mov qword [rbp-40], rax
    mov rax, qword [rbp-40]
    jmp .L_add_end
.L_add_end:
    mov rsp, rbp
    pop rbp
    ret

main:
    push rbp
    mov rbp, rsp
    sub rsp, 32
.L_main_entry:
    mov rdi, 2
    mov rsi, 3
    call add
    mov qword [rbp-16], rax
    mov rax, qword [rbp-16]
    mov qword [rbp-8], rax
    mov rax, qword [rbp-8]
    mov qword [rbp-24], rax
    mov rax, qword [rbp-24]
    jmp .L_main_end
.L_main_end:
    mov rsp, rbp
    pop rbp
    ret
